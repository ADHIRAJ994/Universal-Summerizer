{
    "project_name": "Universal Content Summarizer",
    "version": "1.0.0",
    "llm": {
        "provider": "groq",
        "model": "openai/gpt-oss-120b",
        "temperature": 0.1,
        "max_tokens": 2048
    },
    "extraction": {
        "max_content_length": 50000,
        "request_timeout": 30,
        "user_agent": "Mozilla/5.0 (compatible; Summarizer/1.0)"
    },
    "summarization": {
        "chunk_size": 4000,
        "chunk_overlap": 200,
        "max_summary_length": 500,
        "min_summary_length": 100,
        "supported_styles": [
            "brief",
            "detailed",
            "bullet_points",
            "academic",
            "simple"
        ]
    },
    "supported_sources": [
        "website",
        "youtube",
        "pdf",
        "text",
        "wikipedia",
        "news"
    ],
    "mlflow": {
        "experiment_name": "universal-summarizer",
        "tracking_uri": "mlruns"
    }
}